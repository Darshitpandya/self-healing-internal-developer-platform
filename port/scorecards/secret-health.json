{
  "identifier": "secret-health",
  "title": "Secret Health",
  "blueprint": "service",
  "rules": [
    {
      "identifier": "secrets-healthy",
      "title": "All Secrets Healthy",
      "level": "Gold",
      "query": {
        "combinator": "and",
        "conditions": [
          { "property": "secret_health_status", "operator": "=", "value": "healthy" }
        ]
      }
    },
    {
      "identifier": "no-expiring-secrets",
      "title": "No Secrets Expiring Within 14 Days",
      "level": "Silver",
      "query": {
        "combinator": "or",
        "conditions": [
          { "property": "secret_days_to_expiry", "operator": "isEmpty" },
          { "property": "secret_days_to_expiry", "operator": ">", "value": 14 }
        ]
      }
    }
  ]
}
